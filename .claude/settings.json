{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run build:*)",
      "Bash(tsc:*)",
      "Bash(ls:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(npm run autopost:*)",
      "Bash(tsx:*)",
      "Bash(bash scripts/notify-slack.sh:*)",
      "WebFetch"
    ],
    "deny": [
      "Read(.env)",
      "Read(./.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(**/.env)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git filter-branch:*)"
    ]
  }
}
